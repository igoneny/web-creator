# ============================================================
# Webcraft AI — Variables de entorno
# Copia este archivo a .env.local y rellena tus valores reales
# ============================================================

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXX

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXX

# Vercel — https://vercel.com/account/tokens
VERCEL_TOKEN=XXXXXXXXXXXXXXXX
VERCEL_TEAM_ID=                      # Vacío si es cuenta personal

# Vercel KV — se crea en vercel.com/dashboard → Storage → KV
KV_URL=redis://XXXXXXXXXXXXXXXX
KV_REST_API_URL=https://XXXXXXXXXXXXXXXX.upstash.io
KV_REST_API_TOKEN=XXXXXXXXXXXXXXXX
KV_REST_API_READ_ONLY_TOKEN=XXXXXXXXXXXXXXXX

# URL pública de tu app
NEXT_PUBLIC_URL=http://localhost:3000

# Admin panel
ADMIN_PASSWORD=tu-contraseña-segura-aqui          # Contraseña para entrar al panel
ADMIN_SESSION_TOKEN=un-token-aleatorio-largo-aqui  # Token de sesión (genera con: openssl rand -hex 32)
ADMIN_SECRET_KEY=otra-clave-para-api-interna       # Clave para llamadas internas a /api/admin
